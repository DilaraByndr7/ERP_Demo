# Local PostgreSQL örneği
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=24h
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_demo
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
PGDATA=%USERPROFILE%\postgres-data
PG_BIN_DIR=%USERPROFILE%\Downloads\postgresql-18.3-2-windows-x64-binaries\pgsql\bin
ALLOW_DESTRUCTIVE_SEED=false
