{
  "name": "erp-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "ERP Demo Backend API",
  "main": "server-postgres.js",
  "scripts": {
    "start": "node server-postgres.js",
    "dev": "node --watch server-postgres.js",
    "db:start:docker": "docker compose -f docker-compose.yml up -d",
    "db:stop:docker": "docker compose -f docker-compose.yml down",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed.js",
    "db:setup": "node scripts/setup-db.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "fs-extra": "^11.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  }
}
